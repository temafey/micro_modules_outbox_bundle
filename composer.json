{
    "name": "micro-module/outbox-bundle",
    "description": "Transactional Outbox Pattern bundle for reliable event delivery in event-sourced systems",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "doctrine/dbal": "^4.4",
        "psr/log": "^2.0 || ^3.0",
        "ramsey/uuid": "^4.0",
        "symfony/console": "^7.0 || ^8.0",
        "symfony/dependency-injection": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0"
    },
    "suggest": {
        "broadway/broadway": "Required for OutboxAwareEventStore and BroadwayDomainEventSerializer",
        "micro-module/enqueue": "Required for EventPublisher (RabbitMQ queue publishing)",
        "open-telemetry/api": "Required for OpenTelemetryOutboxMetrics",
        "open-telemetry/sdk": "Required for OpenTelemetryOutboxMetrics implementation"
    },
    "require-dev": {
        "broadway/broadway": "^3.0",
        "mockery/mockery": "^1.6",
        "open-telemetry/api": "^1.0",
        "open-telemetry/sdk": "^1.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.0",
        "symplify/easy-coding-standard": "^12.0"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "MicroModule\\Outbox\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MicroModule\\Outbox\\Tests\\": "tests/"
        }
    }
}
